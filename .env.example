# ═══════════════════════════════════════════════════════════════════════
# Taia Tiniyara — Environment Variables
# ═══════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# Warnings are printed at startup for any missing or default variables.
# ═══════════════════════════════════════════════════════════════════════

# ── Admin / Auth (REQUIRED) ────────────────────────────────────────────

# The password used to log into the admin panel at /admin/login.
# Must be at least 8 characters.
ADMIN_PASSWORD=your-admin-password

# HMAC signing secret for admin session cookies.
# Generate a strong random secret: openssl rand -hex 32
SESSION_SECRET=change-me-in-production

# ── Site (REQUIRED) ────────────────────────────────────────────────────

# Public URL of the site. Must be set at build time.
# Local dev: http://localhost:3000
# Production: https://taiatiniyara.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Cloudflare R2 (REQUIRED) ───────────────────────────────────────────
# Used for image uploads and blog content storage.
#
# 1. Create an R2 bucket in the Cloudflare dashboard.
# 2. Go to R2 → Manage R2 API Tokens → Create API Token.
#    - Permissions: Object Read & Write
#    - Scope: your bucket name
# 3. Copy the Access Key ID and Secret Access Key.
#    (Secret is shown only once — save it immediately.)
# 4. Get your Account ID from:
#    Cloudflare Dashboard → Workers & Pages → Account ID (right sidebar)
#    OR from the R2 dashboard URL: /accounts/<THIS-IS-IT>/r2/
# 5. Set a custom domain for the bucket (optional) for R2_PUBLIC_URL.

R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET_NAME=your-bucket-name

# Public URL for your R2 bucket. Can be:
#   - The default r2.dev domain: https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev
#   - A custom domain connected to the bucket: https://cdn.taiatiniyara.com
# If unset, *.r2.dev remote patterns are used for image optimization.
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ── SMTP / Email (OPTIONAL — contact form notifications) ───────────────
# If any SMTP variable is set, ALL must be set.
# If left unset, the contact form will still save submissions to the DB
# but will not send email notifications.

# SMTP server hostname.
# Hostinger: smtp.hostinger.com
# Gmail:     smtp.gmail.com (requires app password)
# Resend:    smtp.resend.com
SMTP_HOST=smtp.example.com

# SMTP port. 465 for SSL, 587 for STARTTLS. Defaults to 587.
SMTP_PORT=587

# SMTP username (typically the full email address).
SMTP_USER=your-smtp-user

# SMTP password or app-specific password.
SMTP_PASS=your-smtp-password

# From address for outgoing emails.
# Format: "Name <email@domain.com>" or just "email@domain.com"
SMTP_FROM="Taia Tiniyara <noreply@taiatiniyara.com>"

# Email address where contact form notifications are sent.
# Defaults to taiatiniyara@gmail.com if unset.
NOTIFICATION_EMAIL=taiatiniyara@gmail.com
